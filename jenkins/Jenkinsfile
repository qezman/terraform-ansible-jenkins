pipeline {
    agent any

    environment {
        APP_SERVER_IP   = '44.204.111.101'
        ANSIBLE_DIR     = 'ansible'
        SSH_KEY         = credentials('ansible-ssh-key')
    }

    stages {

        // pull latest code from gh
        stage('Checkout') {
            steps {
                checkout scm
                echo 'Code checked out successfully'
            }
        }

        // run Ansible against the app server only
        stage('Deploy') {
            steps {
                dir("${ANSIBLE_DIR}") {
                    sh """
                        ANSIBLE_HOST_KEY_CHECKING=False \
                        ansible-playbook \
                            -i inventory.ini \
                            --limit app \
                            --private-key ${SSH_KEY} \
                            -u ubuntu \
                            site.yml
                    """
                }
            }
        }

        // verify app is responding on port 80
        stage('Verify') {
            steps {
                sh "curl -f --retry 5 --retry-delay 10 http://${APP_SERVER_IP}"
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed — check logs above'
        }
        always {
            cleanWs()
        }
    }
}